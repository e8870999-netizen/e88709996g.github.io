    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0a0e27 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
            color: #ffffff;
        }

        /* Animated background particles */
        .bg-particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(0, 212, 255, 0.6);
            border-radius: 50%;
            animation: float 15s infinite ease-in-out;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) translateX(50px); opacity: 0; }
        }

        /* Main container */
        .container {
            max-width: 1400px;
            width: 95%;
            padding: 20px;
            z-index: 1;
            text-align: center;
        }

        /* Logo/Header */
        .header {
            margin-bottom: 30px;
            animation: fadeInDown 0.8s ease-out;
        }

        .logo {
            font-size: 2.5em;
            font-weight: 800;
            background: linear-gradient(135deg, #00d4ff 0%, #0066ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.5);
            letter-spacing: 2px;
            transition: transform 0.3s;
        }

        .logo:hover {
            transform: scale(1.05);
        }

        .tagline {
            font-size: 1.1em;
            color: #8b9dc3;
            margin-top: 10px;
            font-weight: 300;
        }

        /* Main banner image */
        .banner-container {
            position: relative;
            width: 100%;
            max-width: 1280px;
            margin: 0 auto 40px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 80px rgba(0, 212, 255, 0.3);
            animation: fadeInUp 1s ease-out 0.3s both;
            display: block;
            text-decoration: none;
            transition: transform 0.3s;
        }

        .banner-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 100px rgba(0, 212, 255, 0.5);
        }

        .banner-image {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.5s;
        }

        .banner-container:hover .banner-image {
            transform: scale(1.02);
        }

        /* CTA Button */
        .cta-container {
            margin: 40px 0;
            animation: fadeInUp 1s ease-out 0.6s both;
        }

        .cta-button {
            display: inline-block;
            padding: 20px 60px;
            font-size: 1.4em;
            font-weight: 700;
            color: #ffffff;
            background: linear-gradient(135deg, #00d4ff 0%, #0066ff 100%);
            border: none;
            border-radius: 50px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 40px rgba(0, 102, 255, 0.4);
            position: relative;
            overflow: hidden;
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .cta-button:hover::before {
            left: 100%;
        }

        .cta-button:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 15px 60px rgba(0, 212, 255, 0.6);
        }

        .cta-button:active {
            transform: translateY(-1px) scale(1.02);
        }

        /* Sticky floating button */
        .sticky-cta {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: pulse 2s infinite;
            display: none;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        /* SEO Keywords Section (hidden but crawlable) */
        .seo-keywords {
            position: absolute;
            left: -9999px;
            width: 1px;
            height: 1px;
            overflow: hidden;
        }

        /* Features grid */
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 50px 0;
            animation: fadeInUp 1s ease-out 0.9s both;
        }

        .feature-card {
            background: rgba(26, 31, 58, 0.6);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 15px;
            padding: 25px;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.2);
        }

        .feature-icon {
            font-size: 2.5em;
            margin-bottom: 15px;
        }

        .feature-title {
            font-size: 1.2em;
            font-weight: 600;
            margin-bottom: 10px;
            color: #00d4ff;
        }

        .feature-description {
            color: #8b9dc3;
            line-height: 1.6;
        }

        /* Footer */
        .footer {
            margin-top: 60px;
            padding: 30px;
            border-top: 1px solid rgba(0, 212, 255, 0.2);
            color: #8b9dc3;
            font-size: 0.9em;
        }

        .footer a {
            color: #00d4ff;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer a:hover {
            color: #ffffff;
        }

        /* Animations */
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .logo {
                font-size: 1.8em;
            }

            .tagline {
                font-size: 0.9em;
            }

            .cta-button {
                padding: 15px 40px;
                font-size: 1.2em;
            }

            .features {
                grid-template-columns: 1fr;
            }

            .sticky-cta {
                bottom: 10px;
                right: 10px;
                left: 10px;
            }

            .sticky-cta .cta-button {
                width: 100%;
                text-align: center;
                padding: 15px 30px;
                font-size: 1.1em;
            }
        }

        /* Preloader */
        .preloader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0a0e27;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.5s, visibility 0.5s;
        }

        .preloader.hidden {
            opacity: 0;
            visibility: hidden;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(0, 212, 255, 0.2);
            border-top-color: #00d4ff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
