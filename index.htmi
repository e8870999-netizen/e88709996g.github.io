    <script>
        // Preloader
        window.addEventListener('load', function() {
            setTimeout(function() {
                document.getElementById('preloader').classList.add('hidden');
            }, 500);
        });

        // Generate background particles
        function createParticles() {
            const particlesContainer = document.getElementById('particles');
            const particleCount = 50;

            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (10 + Math.random() * 10) + 's';
                particlesContainer.appendChild(particle);
            }
        }

        createParticles();

        // Tracking functions
        function trackCTA() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'click', {
                    'event_category': 'CTA',
                    'event_label': 'Main CTA Button',
                    'value': 1
                });
            }
            if (typeof ym !== 'undefined') {
                ym(XXXXXXXX, 'reachGoal', 'CTA_CLICK');
            }
            console.log('Main CTA clicked');
        }

        function trackBannerClick() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'click', {
                    'event_category': 'Banner',
                    'event_label': 'Banner Click',
                    'value': 1
                });
            }
            if (typeof ym !== 'undefined') {
                ym(XXXXXXXX, 'reachGoal', 'BANNER_CLICK');
            }
            console.log('Banner clicked');
        }

        function trackLogoClick() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'click', {
                    'event_category': 'Logo',
                    'event_label': 'Logo Click',
                    'value': 1
                });
            }
            if (typeof ym !== 'undefined') {
                ym(XXXXXXXX, 'reachGoal', 'LOGO_CLICK');
            }
            console.log('Logo clicked');
        }

        function trackStickyCTA() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'click', {
                    'event_category': 'Sticky_CTA',
                    'event_label': 'Floating Button',
                    'value': 1
                });
            }
            if (typeof ym !== 'undefined') {
                ym(XXXXXXXX, 'reachGoal', 'STICKY_CTA_CLICK');
            }
            console.log('Sticky CTA clicked');
        }

        function trackFooterLink() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'click', {
                    'event_category': 'Footer',
                    'event_label': 'Footer CTA Link',
                    'value': 1
                });
            }
            if (typeof ym !== 'undefined') {
                ym(XXXXXXXX, 'reachGoal', 'FOOTER_CLICK');
            }
            console.log('Footer link clicked');
        }

        // Show sticky button after scroll
        window.addEventListener('scroll', function() {
            const stickyBtn = document.querySelector('.sticky-cta');
            if (window.scrollY > 500) {
                stickyBtn.style.display = 'block';
            } else {
                stickyBtn.style.display = 'none';
            }
        });

        // Track scroll depth
        let maxScroll = 0;
        window.addEventListener('scroll', function() {
            const scrollPercentage = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
            
            if (scrollPercentage > maxScroll) {
                maxScroll = scrollPercentage;
                
                if (maxScroll > 25 && maxScroll < 30) {
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'scroll', {'event_category': 'Engagement', 'event_label': '25%'});
                    }
                } else if (maxScroll > 50 && maxScroll < 55) {
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'scroll', {'event_category': 'Engagement', 'event_label': '50%'});
                    }
                } else if (maxScroll > 75 && maxScroll < 80) {
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'scroll', {'event_category': 'Engagement', 'event_label': '75%'});
                    }
                } else if (maxScroll > 95) {
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'scroll', {'event_category': 'Engagement', 'event_label': '100%'});
                    }
                }
            }
        });

        // Lazy loading optimization
        if ('IntersectionObserver' in window) {
            const imageObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        img.src = img.dataset.src || img.src;
                        img.classList.add('loaded');
                        observer.unobserve(img);
                    }
                });
            });

            document.querySelectorAll('img').forEach(img => imageObserver.observe(img));
        }

        // Smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>

